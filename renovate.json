{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:recommended",
    "group:allNonMajor"
  ],
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "postUpdateOptions": ["gomodTidy"],
  "gomod": {
      "enabled": true
  },
  "packageRules": [
    {
      "groupName": "server",
      "enabled": false,
      "matchPackageNames": [
        "/.*Campus-Backend/.*/"
      ]
    },
    {
      "groupName": "googleapis",
      "automerge": true,
      "matchPackageNames": [
        "/google.golang.org/genproto/googleapis/api/"
      ]
    }
  ]
}
